---
# ============================================================
# Word DESIGN.md — 中文 Word 文件設計系統規格
# ============================================================
# 規格基礎：Google Stitch DESIGN.md format（適配 Word 中文場景）
# 來源：F-017 文本參謀長 + 火神鍛造工頭跨客戶協作鍛造（2026-04-30）
# 借鑑：impeccable v3.0.5（pbakaus/impeccable）
#
# 跟 Stitch 規格的差異（Word dialect）：
#   ✅ 保留：colors / typography / spacing / components
#   ✏️ 重新利用：elevation → sections（Word 的層次來自分節）
#   ❌ 砍掉：rounded（Word 沒元件圓角）
#   ➕ 新增：cjk（雙字型/避頭尾/中英間距）+ numbering（多級列表/編號）
#
# 介面分工：
#   - 作者讀的：下方 markdown body 6 段（人話）
#   - 表弟動的：本 frontmatter（程式吃）
#   - 同步機制：scripts/load_design.py 解析此 YAML → DESIGN_SYSTEM dict
#   - 權威：YAML 是真相源；markdown body 是給作者拍板用的人話描述
# ============================================================

name: "[文件標題]"
description: "[一句話定位：這是什麼書/誰在讀/什麼氣質]"

# ---------- 色彩 ----------
colors:
  primary: "#1A1A2E"       # 主色（標題/強調）
  secondary: "#4A4A6A"     # 次色（副標/小標題）
  accent: "#2E86C1"        # 強調色（連結/重點/圖表）
  body: "#333333"          # 內文色（避免 #000，傷視疲勞）
  caption: "#666666"       # 輔助色（圖說/腳註）
  table_header_bg: "#E8EAED"
  table_border: "#CCCCCC"
  background: "#FAFAF8"    # 背景紙白（避免 #FFF，加少量暖調）

# ---------- 字體階層 ----------
# 階層之間 ratio 必須 ≥ 1.25（modular scale）
# 中文行距 1.5-2.0 倍（不是西文的 1.5 倍）
typography:
  display:
    fontFamily: "Cormorant Garamond, Georgia, serif"
    fontFamilyCJK: "思源宋體"
    fontSize: 28              # pt
    fontWeight: 600
    lineSpacing: 1.3
    spaceBefore: 36
    spaceAfter: 18

  heading_1:
    fontFamily: "Times New Roman"
    fontFamilyCJK: "思源宋體"
    fontSize: 18
    fontWeight: 700
    lineSpacing: 1.3
    spaceBefore: 24
    spaceAfter: 12

  heading_2:
    fontFamily: "Times New Roman"
    fontFamilyCJK: "思源宋體"
    fontSize: 14
    fontWeight: 700
    lineSpacing: 1.4
    spaceBefore: 18
    spaceAfter: 6

  heading_3:
    fontFamily: "Times New Roman"
    fontFamilyCJK: "思源宋體"
    fontSize: 12
    fontWeight: 700
    lineSpacing: 1.5
    spaceBefore: 12
    spaceAfter: 6

  body:
    fontFamily: "Times New Roman"
    fontFamilyCJK: "思源宋體"
    fontSize: 11
    fontWeight: 400
    lineSpacing: 1.75         # 中文需要的呼吸感
    spaceBefore: 0
    spaceAfter: 6

  body_emphasis:
    fontFamily: "Times New Roman"
    fontFamilyCJK: "思源宋體"
    fontSize: 11
    fontWeight: 700           # 內文加粗強調
    lineSpacing: 1.75

  caption:
    fontFamily: "Times New Roman"
    fontFamilyCJK: "思源宋體"
    fontSize: 9
    fontWeight: 400
    lineSpacing: 1.4

  quote:
    fontFamily: "Times New Roman"
    fontFamilyCJK: "思源宋體"
    fontSize: 11
    fontWeight: 400
    lineSpacing: 1.6

# ---------- 間距系統 ----------
# 基礎單位 6pt，所有垂直間距是 6 的整數倍（vertical rhythm）
spacing:
  unit: 6                     # pt 基礎單位（4/6/8 任選一個 commit）
  margin_top: "2.54cm"        # 紙張上邊距
  margin_bottom: "2.54cm"
  margin_left: "3.17cm"
  margin_right: "3.17cm"
  paragraph_indent: "0"       # 首行縮排（書籍寫 "0.74cm" 約 2 字；商業寫 "0"）
  list_indent: "0.74cm"       # 列表縮排
  quote_indent: "1.5cm"       # 引用塊縮排

# ---------- CJK 中文特化 ----------
# 文本參謀長中文場景必經設定
cjk:
  pangu_spacing: true         # 中英自動加空格
  kinsoku: true               # 避頭尾
  overflow_punct: true        # 標點壓縮
  auto_space_de: true         # CJK 跟英文自動間距
  auto_space_dn: true         # CJK 跟數字自動間距
  punct_width: "fullwidth"    # 標點寬度：fullwidth / halfwidth

# ---------- 編號 ----------
numbering:
  heading_style: "1.1.1"      # "1.1.1" / "壹貳參" / "I.A.1" / "第一章/第一節"
  list_marker: "•"            # 項目符號："•" / "－" / "●" / "▪"
  toc_depth: 3                # 目錄深度（1-9）
  figure_prefix: "圖"         # "圖" / "Figure" / "圖表"
  table_prefix: "表"          # "表" / "Table"

# ---------- 分節（Word 的層次：取代 Stitch 的 elevation）----------
sections:
  page_size: "A4"             # A4 / Letter / B5 / 自訂
  orientation: "portrait"     # portrait / landscape
  different_first_page: true  # 首頁頁首頁尾不同
  even_odd_headers: false     # 奇偶頁不同
  page_number_start: 1        # 頁碼從第幾頁開始
  page_number_position: "footer_center"  # footer_center / footer_right / header_right
  cover_page: true            # 是否有封面（封面通常無頁碼）

# ---------- 元件樣式（引用 primitives）----------
components:
  body_paragraph:
    typography: "{typography.body}"
    indent: "{spacing.paragraph_indent}"

  heading_1_style:
    typography: "{typography.heading_1}"
    color: "{colors.primary}"

  heading_2_style:
    typography: "{typography.heading_2}"
    color: "{colors.primary}"

  heading_3_style:
    typography: "{typography.heading_3}"
    color: "{colors.secondary}"

  table_header:
    backgroundColor: "{colors.table_header_bg}"
    typography: "{typography.body_emphasis}"

  table_cell:
    typography: "{typography.body}"
    border_color: "{colors.table_border}"

  quote_block:
    typography: "{typography.quote}"
    color: "{colors.caption}"
    indent: "{spacing.quote_indent}"

  caption_text:
    typography: "{typography.caption}"
    color: "{colors.caption}"

  link:
    typography: "{typography.body}"
    color: "{colors.accent}"
---

# Design System: [文件標題]

> **作者讀的就是這份 markdown body**。設計決策都用人話描述，看不懂任何一條請直接跟表弟說。
> 上方 YAML frontmatter 是程式吃的版本，作者忽略即可。
>
> 註：跑 `load_design.py --validate` 時模板本身會 WARN 兩條（部分 token 在 placeholder 段未展示用法，屬預期行為）。填入實際內容後重跑即可。

